# Normalize line endings so the starter behaves the same on Windows and Unix.
* text=auto eol=lf

# Windows-only script keeps CRLF.
*.ps1 text eol=crlf

# Shell script must stay LF so it runs on macOS and Linux.
*.sh text eol=lf

# Binary assets: never touch.
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.zip binary
