# Dependencies
/vendor/
/node_modules/

# Build artifacts (keep the dist folder, ignore the zips inside it)
/build/
/dist/*
!/dist/.gitkeep
*.zip

# Tooling caches
/.phpunit.result.cache
.phpunit.cache/
/phpstan.neon
.phpstan.cache/
/coverage/

# Local WordPress / test installs
/wp/
/wordpress/
/.wp-env/

# Environment and secrets (never commit these)
# Scoped to key/cert extensions and a dedicated secrets/ folder so real source
# files (for example license-key-validator.php) are never caught by accident.
.env
.env.*
*.key
*.pem
*.p12
*.pfx
/secrets/

# Logs and OS cruft
*.log
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.sublime-*

# Personal Claude Code settings (shared settings.json can still be committed)
.claude/settings.local.json
