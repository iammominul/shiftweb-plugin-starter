# Dependencies
/vendor/
/node_modules/

# Build artifacts (keep the dist folder, ignore the zips inside it)
/build/
/dist/*
!/dist/.gitkeep
*.zip

# Tooling caches
/.phpunit.result.cache
/phpstan.neon
.phpstan.cache/

# Environment and secrets
.env
.env.*
*.key
*.pem

# Logs and OS cruft
*.log
.DS_Store
Thumbs.db

# Editor
.idea/
.vscode/
*.sublime-*

# Personal Claude Code settings (shared settings.json can still be committed)
.claude/settings.local.json
