<?xml version="1.0"?>
<ruleset name="{{PLUGIN_NAME}}">
	<description>WordPress Coding Standards for {{PLUGIN_NAME}}.</description>

	<file>.</file>

	<exclude-pattern>*/vendor/*</exclude-pattern>
	<exclude-pattern>*/node_modules/*</exclude-pattern>
	<exclude-pattern>*/tests/*</exclude-pattern>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<!-- Minimum supported versions. -->
	<config name="minimum_supported_wp_version" value="6.0"/>
	<config name="testVersion" value="7.4-"/>

	<rule ref="WordPress"/>
	<rule ref="PHPCompatibilityWP"/>

	<!-- src/ uses PSR-4 StudlyCase class files (Plugin.php), not the WordPress
	     core class-*.php convention. Keep the filename rules everywhere else. -->
	<rule ref="WordPress.Files.FileName">
		<exclude-pattern>src/*</exclude-pattern>
	</rule>

	<!-- Enforce our prefixes and text domain. -->
	<rule ref="WordPress.NamingConventions.PrefixAllGlobals">
		<properties>
			<property name="prefixes" type="array">
				<element value="{{PLUGIN_PREFIX}}"/>
				<element value="{{PLUGIN_CONSTANT}}"/>
				<element value="{{PLUGIN_NAMESPACE}}"/>
			</property>
		</properties>
	</rule>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="{{TEXT_DOMAIN}}"/>
			</property>
		</properties>
	</rule>
</ruleset>
